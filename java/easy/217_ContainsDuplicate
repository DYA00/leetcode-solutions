//Solution for the problem, Contains Duplicate in the leetcode.
class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashSet<Integer> once = new HashSet<>();

        for (int i = 0; i < nums.length; i++) {
            if (once.contains(nums[i])) {
                return true;
            }
            else {
                once.add(nums[i]);
            }
        }

        return false;
    }
}
